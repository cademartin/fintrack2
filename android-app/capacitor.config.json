{
  "appId": "com.teatracker.app",
  "appName": "Tea Tracker",
  "webDir": "www",
  "server": {
    "androidScheme": "https"
  },
  "android": {
    "backgroundColor": "#f0fdf4",
    "allowMixedContent": false,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "backgroundColor": "#16a34a",
      "showSpinner": false,
      "androidScaleType": "CENTER_CROP"
    }
  }
}
